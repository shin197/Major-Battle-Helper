{
  "name": "major-battle-helper",
  "displayName": "Major battle helper",
  "version": "1.0.0",
  "description": "CCFolia Helper Extension",
  "author": "Skywindragoon",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build --env=.env.dev --zip",
    "build:major": "plasmo build --env=.env.major --zip",
    "build:public": "plasmo build --env=.env.public --zip",
    "predev": "node set-icon-major.js",
    "prebuild:major": "node set-icon-major.js",
    "prebuild:public": "node set-icon.js"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "lodash": "^4.17.21",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "name": "$PLASMO_PUBLIC_EXT_NAME",
    "description": "$PLASMO_PUBLIC_EXT_DESC",
    "host_permissions": [
      "https://ccfolia.com/*"
    ],
    "permissions": [
      "debugger",
      "storage",
      "activeTab",
      "scripting"
    ],
    "content_scripts": [
      {
        "matches": [
          "https://ccfolia.com/*"
        ],
        "js": [
          "$MAJOR_BATTLE_SCRIPT_ISOLATED"
        ]
      }
    ]
  }
}
